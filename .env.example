# Copy to `.env` and adjust for your environment.
# All values below are optional and fall back to the defaults in app/config.py.

# --- Application metadata ---
APP_NAME=shadow-mode-llm-evaluator
# One of: local | development | staging | production
ENVIRONMENT=local

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000

# --- Logging ---
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# true => structured JSON logs; false => human-readable console logs
LOG_JSON=true

# --- Outbound HTTP client ---
HTTP_TIMEOUT_SECONDS=30

# --- Primary LLM (DigitalOcean Serverless Inference) ---
PRIMARY_LLM_ENDPOINT=https://inference.do-ai.run/v1/chat/completions
# Default model applied when the request body omits "model".
PRIMARY_LLM_MODEL=llama3.3-70b-instruct
# DigitalOcean model access key (Bearer token). Required for /v1/chat.
PRIMARY_LLM_API_KEY=
PRIMARY_LLM_TIMEOUT_SECONDS=30
# Retries beyond the first attempt for transient failures (timeouts, 5xx, 429).
PRIMARY_LLM_MAX_RETRIES=2
# Base delay (seconds) for exponential backoff between retries.
PRIMARY_LLM_BACKOFF_BASE_SECONDS=0.5
# Upper bound (seconds) on any single backoff / Retry-After sleep.
PRIMARY_LLM_BACKOFF_MAX_SECONDS=8

# --- Candidate LLM (shadow mode) ---
# Toggle detached shadow calls to the candidate model.
CANDIDATE_LLM_ENABLED=true
CANDIDATE_LLM_ENDPOINT=https://inference.do-ai.run/v1/chat/completions
# Default model applied to the shadow payload when it omits "model".
CANDIDATE_LLM_MODEL=llama3.3-70b-instruct
# DigitalOcean model access key for the candidate. Shadow calls are skipped if empty.
CANDIDATE_LLM_API_KEY=
CANDIDATE_LLM_TIMEOUT_SECONDS=30

# --- Shadow execution (bounded concurrency) ---
# Max pending shadow jobs; when the queue is full, the shadow job is dropped.
SHADOW_QUEUE_SIZE=100
# Fixed number of workers draining the shadow queue.
SHADOW_WORKERS=4
# Initial % of requests mirrored to the candidate (0-100). Adjustable at runtime
# via PUT /config; the primary model always executes regardless.
SHADOW_PERCENTAGE=100

# --- Persistence (SQLite) ---
# Path to the SQLite database for divergence traces (created automatically).
SQLITE_DB_PATH=shadow_traces.db
